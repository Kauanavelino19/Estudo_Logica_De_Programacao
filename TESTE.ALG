algoritmo "Teste"
var
   I,C: inteiro
inicio
      EscrevaL("========================")
      EscrevaL(" E S T R U T U R A      P A R A")
      EscrevaL("========================")
      Escreva("Digite um numero qualquer: ")
      Leia(C)
      Para I:= 1 ate C faca
           EscrevaL(C)
      FimPara
fimalgoritmo