algoritmo "Passagem de parametro por valor"
var
 X,Y: Inteiro
Procedimento Soma(A,B: Inteiro)
Inicio
  EscrevaL("Recebi valor ", A)
  EscrevaL("Recebi valor ", B)
  EscrevaL("A soma vale ", A + B)
FimProcedimento
inicio

      Escreva("Digite um numero: ")
      Leia(X)

      EscrevaL("Digite outro numero: ")
      Leia(Y)
      
      Soma(X,Y)
fimalgoritmo