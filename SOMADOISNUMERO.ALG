algoritmo "semnome"
var
   N1, N2: Inteiro
   media: Real
inicio
      Escreva("Informe um numero: ")
      Leia(N1)
      Escreva("Informe outro numero: ")
      Leia(N2)
      media <- (N1 + N2)/ 2
      
      EscrevaL("A media entre ",N1, " e ", N2, " e igual a " , media)
fimalgoritmo