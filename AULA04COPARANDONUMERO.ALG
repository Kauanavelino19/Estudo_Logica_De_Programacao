algoritmo "Aula04CoparandoNumero"
//  
//  
var
  A: Vetor[1..3] de Inteiro
inicio
     //Escreva("A: ")
      //Leia(A)

      //Escreva("B: ")
      //Leia(B)
      
      //Escreva("C: ")
      //Leia(C)

      A[1]<-2
      A[2]<-3
      A[3] <- 5
      
      EscrevaL((A[1]>A[2]) ou (A[3]>A[1]))
fimalgoritmo