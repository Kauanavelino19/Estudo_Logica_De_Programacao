algoritmo "Aula04CoparandoNumero"
//  
//  
var
  A,B,C:Inteiro
inicio
     //Escreva("A: ")
      //Leia(A)

      //Escreva("B: ")
      //Leia(B)
      
      //Escreva("C: ")
      //Leia(C)

      A<-2
      B<-3
      C <- 5
      
      EscrevaL((A>B) ou (C>A))
fimalgoritmo